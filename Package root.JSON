{
  "name": "ministore",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:storefront": "npm run dev --workspace=@ministore/storefront",
    "dev:admin": "npm run dev --workspace=@ministore/admin",
    "build:storefront": "npm run build --workspace=@ministore/storefront",
    "build:admin": "npm run build --workspace=@ministore/admin",
    "lint": "npm run lint:prettier && npm run lint:eslint && npm run lint:styles",
    "lint:prettier": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:eslint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "lint:styles": "stylelint '**/*.css'",
    "lint:styles:fix": "stylelint '**/*.css' --fix",
    "lint:fix": "npm run lint:prettier:fix && npm run lint:eslint:fix && npm run lint:styles:fix"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.53.0",
    "eslint-plugin-react": "^7.33.2",
    "prettier": "^3.0.3",
    "stylelint": "^15.10.3",
    "stylelint-config-standard": "^34.0.0",
    "typescript": "^5.2.2"
  }
}